{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dbc",
  "version": "0.1.0",
  "identifier": "tech.columnar.dbc.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash gui/scripts/build-sidecar.sh --target $TAURI_ENV_TARGET_TRIPLE",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "dbc",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Columnar Technologies Inc.",
    "category": "DeveloperTool",
    "shortDescription": "ADBC Driver Manager GUI",
    "copyright": "\u00a9 2026 Columnar Technologies Inc.",
    "externalBin": [
      "binaries/dbc"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER_PUBKEY_REPLACE_WITH_REAL_KEY",
      "endpoints": [
        "https://dbc.columnar.tech/gui/updater/{{target}}/{{current_version}}"
      ]
    }
  }
}
