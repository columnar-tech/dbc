{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell-scope",
  "description": "Restrict shell execute to dbc sidecar only",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [{"name": "dbc", "sidecar": true}]
    }
  ]
}
